    #平衡二叉树 最主要的就是AVL树  特征：适合动态查找 是更保险的二叉排序树 因为二叉排序树容易长歪 所以需要一个能让他更平衡的东西 让他的时间复杂度保持在 O(log n)
    #AVL树                         ”长歪“就是 插入和删除会让他变得“不平衡” 比如左子树层高为10 右子树层高为1 查找右子树的时候就很快 左子树就很慢
    class AVLNode:
        def __init__(self,k,d):
            self.key = k
            self.data = d
            self.left = None
            self.right = None
            self.ht = 1

        def get_height(self,p):#用来处理 p == None 的条件 而具体的ht会在每次插入 删除 旋转后更新
            return p.ht if p else 0

        def get_bf(self,p):#平衡因子
            if not p: return 0#判断当p不存在时
            left_ht = self.get_height(p.lchild)
            right_ht = self.get_height(p.rchild)
            return left_ht - right_ht

        #右旋
        def right_rotate(self,a):
            b = a.lchild
            a.lchild = b.rchild
            b.rchild = a
            a.ht = max(self.get_height(a.lchild),self.get_height(a.rchild)) + 1#更新a,b的高度 高度是这个节点向下数 到达None之前 最远能有几层 不是节点的层数
            b.ht = max(self.get_height(b.lchild),self.get_height(b.rchild)) + 1#新的层数是他们的大的那个child层的max +  由于旋转后可能会改变孩子 所以不一定是原来的ht - 1
            return b

        #左旋
        def left_rotate(self,a):
            b = a.rchild
            a.rchild = b.lchild
            b.lchild = a
            a.ht = max(self.get_height(a.lchild), self.get_height(a.rchild)) + 1
            b.ht = max(self.get_height(b.lchild), self.get_height(b.rchild)) + 1
            return b

        def LL(self,a):#直接右旋原树
            return self.right_rotate(a)

        def RR(self,a):#直接左旋原树
            return self.left_rotate(a)

        def RL(self,a):#右旋右子树然后整体左旋
            a.rchild = self.right_rotate(a.rchild)
            return self.left_rotate(a)

        def LR(self,a):#左旋左子树然后整体右旋
            a.lchild = self.left_rotate(a.lchild)
            return self.right_rotate(a)

        def balence(self,p):#平衡
            if p == None:return p
            p.ht = max(self.get_height(p.lchild),self.get_height(p.rchild)) + 1
            bf  = self.get_bf(p)

            if bf > 1 and self.get_bf(p.lchild) > 0:#"LL型"  bf > 1:判断左右子树哪个高
                return self.LL(p)

            if bf > 1 and self.get_bf(p.lchild) < 0:#"LR型"  self.get_bf(p.lchild) < 0 通过子树的平衡因子 判断插入的是子树的左孩子还是右孩子
                return self.LR(p)

            if bf < -1 and self.get_bf(p.rchild) < 0:#"RR型"  bf < -1:判断左右子树哪个高
                return self.RR(p)

            if bf < -1 and self.get_bf(p.rchild) > 0:#"RL型"  self.get_bf(p.Rchild) < 0 通过子树的平衡因子 判断插入的是子树的左孩子还是右孩子
                return self.RL(p)

            return p

        def Insert(self,p,k,d):#插入 基本和二叉排序树的插入一样 但最后要balence一下
            if p == None:
                return AVLNode(k,d)

            if k < p.key:
                p.lchild = self.Insert(p.lchild,k,d)
            elif k > p.key:
                p.rchild = self.Insert(p.rchild,k,d)
            else:
                p.data = d
                return p

            return self.balence(p)
