#直接查找  特征：查找量少的
def SeqSearch(R,K):#顺序查找
    n = len(R)
    i = 0
    while i < n and R[i] == K:
        i += 1
    if i == n:
        return -1
    else:
        return i

def SeqSearch2(R,K):#顺序查找 哨兵
    n = len(R)
    i = 0
    R.append(K)
    while R[i] != K:
        i += 1
    if i == n:
        return -1
    else:
        return i



#折半查找 特征：查找有序的 但是插入和删除效率低 不能动态变化
#way1
def BinSearch(R,K):
    n = len(R)
    low = 0
    hight = n-1
    while low < hight:
        mid = (low+hight)//2
        if R[mid] == K:
            return mid
        else:
            if R[mid] < K:
                low = mid +1
            if R[mid] > K:
                hight = mid -1
    return -1

#way2
def BinSearch2(R,K):#递归
    return BinSearch21(R,0,len(R)-1,K)

def BinSearch21(R,low,high,K):
    if low < high:
        mid = (high + low)//2
        if R[mid] == K:
            return mid
        if R[mid] < K:
            return BinSearch2(R,low,mid-1,K)
        else:
            return BinSearch2(R,mid+1,high,K)




